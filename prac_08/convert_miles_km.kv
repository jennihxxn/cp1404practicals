<ConvertMilesKmApp>:
    orientation: 'vertical'
    BoxLayout:
        orientation: 'horizontal'
        Button:
            text: 'Up'
            on_press: root.handle_increment(1)
        TextInput:
            id: input_miles
            text: ''
        Button:
            text: 'Down'
            on_press: root.handle_increment(-1)
    Button:
        text: 'Convert'
        on_press: root.handle_convert()
    Label:
        text: root.result
        color: (1, 1, 0, 1)
    Label:
        text: 'Enter a number and press "Square"'
